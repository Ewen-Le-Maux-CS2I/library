# --- ÉTAPE 1 : Compilation de l'application Angular ---
FROM node:20-alpine AS build
WORKDIR /app

# Copie des fichiers de configuration des dépendances
COPY package*.json ./

# Installation propre et stricte des paquets pour la production
RUN npm ci

# Copie de l'intégralité du code source du frontend
COPY . .

# Compilation de l'application Angular pour la production
# (Génère les fichiers optimisés dans le dossier dist/)
RUN npm run build -- --configuration=production

# --- ÉTAPE 2 : Serveur Web de Production (Nginx) ---
FROM nginx:alpine

# Copie de la configuration personnalisée de Nginx pour gérer le routage Angular (Single Page Application)
COPY <<EOF /etc/nginx/conf.d/default.conf
server {
    listen 80;
    server_name localhost;

    location / {
        root /usr/share/nginx/html;
        index index.html index.htm;
        try_files \$uri \$uri/ /index.html;
    }

    error_page 500 502 503 504 /50x.html;
    location = /50x.html {
        root /usr/share/nginx/html;
    }
}
EOF

# Copie des fichiers HTML/CSS/JS compilés depuis l'étape 1 vers le dossier public de Nginx
# ⚠️ ATTENTION : Vérifiez dans votre projet si le dossier généré est 'dist/frontend/browser' ou 'dist/frontend'
COPY --from=build /app/dist/frontend/browser /usr/share/nginx/html

# Exposition du port 80 pour le trafic HTTP
EXPOSE 80

# Démarrage de Nginx au premier plan
CMD ["nginx", "-g", "daemon off;"]